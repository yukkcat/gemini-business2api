# gemini-refresh-worker 环境变量 / Environment variables
#
# 存储后端（二选一）/ Storage backend (choose one mode)
#
# 模式 A：直连数据库 / Mode A: direct database
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#
# 模式 B：远程项目模式（推荐：远程 beta + 本地 worker）
# Mode B: remote project mode (recommended: remote beta + local worker)
# Worker 通过远程管理接口读写账号与配置 / Worker reads and writes data via remote admin APIs
#   POST /login
#   GET  /admin/settings
#   GET  /admin/accounts-config
#   PUT  /admin/accounts-config
# REMOTE_PROJECT_BASE_URL=https://your-beta-domain.example
# REMOTE_PROJECT_PASSWORD=your_admin_key
#
# 远程模式可选项 / Optional remote settings
# REMOTE_PROJECT_VERIFY_SSL=true
# REMOTE_PROJECT_TIMEOUT_SECONDS=30
# 远程模式默认不继承远程 proxy_for_auth（避免远程 localhost 代理误用到本机）
# Remote mode does NOT inherit remote proxy_for_auth by default.
# 如需继承请手动开启 / Set true only if you really need it.
# REMOTE_PROJECT_USE_REMOTE_PROXY_FOR_AUTH=false
#
# 优先级说明 / Priority note
# 同时设置 DATABASE_URL 与 REMOTE_PROJECT_BASE_URL 时，优先使用远程模式。
# If both DATABASE_URL and REMOTE_PROJECT_BASE_URL are set, remote mode wins.

# 日志级别（DEBUG, INFO, WARNING, ERROR）/ Log level
LOG_LEVEL=INFO

# 健康检查端口（0 = 关闭）/ Health check port (0 = disabled)
HEALTH_PORT=8080

# CLI 交互语言（zh/en，默认 zh）/ CLI language (zh/en, default zh)
# CLI_LANG=zh

# ---- 独立控制（覆盖存储配置）/ Independent overrides (override storage settings) ----

# 强制开启或关闭定时刷新 / Force enable or disable scheduled refresh
# FORCE_REFRESH_ENABLED=true

# 刷新检测间隔（分钟，1-720）/ Refresh interval in minutes (1-720)
# REFRESH_INTERVAL_MINUTES=30

# 刷新窗口（小时，0-24）/ Refresh window in hours (0-24)
# 窗口内将被视为“即将过期”并触发刷新 / Accounts expiring within this window will be refreshed
# REFRESH_WINDOW_HOURS=1

# 浏览器模式（normal / silent / headless）
# Browser mode (normal / silent / headless)
# - normal: 正常有头窗口 / normal headed window
# - silent: 有头但尽量最小化，减少抢焦点 / headed but minimized to reduce focus stealing
# - headless: 无头模式 / headless mode
# BROWSER_MODE=normal
#
# 兼容旧字段（不建议新配置继续使用）/ Legacy compatibility (not recommended for new configs)
# 若设置了 BROWSER_MODE，则 BROWSER_HEADLESS 会被忽略
# If BROWSER_MODE is set, BROWSER_HEADLESS is ignored.
# BROWSER_HEADLESS=false

# 本机认证代理 / Local proxy for authentication
# PROXY_FOR_AUTH=socks5://127.0.0.1:1080

# ---- 账号生命周期管理（覆盖存储配置）/ Account lifecycle overrides ----

# 自动删除凭证已过期账号（true/false）/ Auto-delete accounts with expired credentials
# DELETE_EXPIRED_ACCOUNTS=false

# 活跃账号不足时自动注册（true/false）/ Auto-register accounts when active count is low
# AUTO_REGISTER_ENABLED=false

# 最低活跃账号数（0 = 关闭）/ Minimum active account count (0 = disabled)
# 低于该值会自动补充注册 / New accounts are registered when active count is below this value
# MIN_ACCOUNT_COUNT=0

# ---- 注册参数（覆盖存储配置）/ Registration overrides ----

# DuckMail 注册邮箱域名 / Email domain for DuckMail registration
# REGISTER_DOMAIN=

# 单批注册数量（1-20）/ Accounts to register per batch (1-20)
# REGISTER_DEFAULT_COUNT=1
